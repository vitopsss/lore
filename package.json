{
  "name": "lore",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev:api": "npm --workspace @lore/api run dev",
    "dev:mobile": "npm --workspace @lore/mobile run start",
    "db:migrate": "npm --workspace @lore/api run db:migrate",
    "db:seed": "npm --workspace @lore/api run db:seed",
    "db:setup": "npm --workspace @lore/api run db:setup",
    "typecheck": "npm --workspace @lore/api run typecheck && npm --workspace @lore/mobile run typecheck"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "devDependencies": {
    "@types/react": "~19.2.10"
  }
}
