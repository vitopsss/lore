{
  "name": "lore",
  "private": true,
  "scripts": {
    "dev:api": "cd apps/api && npm run dev",
    "dev:mobile": "cd apps/mobile && npm run start",
    "db:migrate": "cd apps/api && npm run db:migrate",
    "db:seed": "cd apps/api && npm run db:seed",
    "db:setup": "cd apps/api && npm run db:setup",
    "typecheck": "npm run typecheck --workspace @lore/api && npm run typecheck --workspace @lore/mobile"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "devDependencies": {
    "@types/react": "~19.2.10"
  }
}
